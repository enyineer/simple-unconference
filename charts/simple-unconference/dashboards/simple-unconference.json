{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "datasource", "uid": "grafana"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Health",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": []
    },
    {
      "title": "Workers (fresh)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "unit": "short"}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "app_workers_total", "refId": "A"}]
    },
    {
      "title": "Stale workers",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 2}]}, "unit": "short"}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "app_workers_stale_total", "refId": "A"}]
    },
    {
      "title": "Global metrics stale",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"text": "fresh", "color": "green"}, "1": {"text": "STALE", "color": "red"}}, "type": "value"}], "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}, "unit": "none"}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "app_metrics_global_stale", "refId": "A"}]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "app_uptime_seconds", "refId": "A"}]
    },
    {
      "title": "Realtime",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 101,
      "panels": []
    },
    {
      "title": "SSE active connections",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "id": 5,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["last", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "stacking": {"mode": "none"}}, "unit": "short"}, "overrides": []},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "sum(realtime_sse_active_connections)", "legendFormat": "total", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "realtime_sse_active_connections", "legendFormat": "worker {{worker}}", "refId": "B"}
      ]
    },
    {
      "title": "Bus events published (rate / 5m, by kind)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "id": 6,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["last", "mean"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "stacking": {"mode": "normal"}}, "unit": "cps"}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "sum by (kind) (rate(bus_published_total[5m]))", "legendFormat": "{{kind}}", "refId": "A"}]
    },
    {
      "title": "Storage",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 102,
      "panels": []
    },
    {
      "title": "Data volume used",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 15},
      "id": 7,
      "options": {"orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showThresholdLabels": false, "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.85}, {"color": "red", "value": 0.95}]}}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "storage_pvc_used_bytes / storage_pvc_total_bytes", "refId": "A"}]
    },
    {
      "title": "SQLite file size",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 15},
      "id": 8,
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "single", "sort": "none"}},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20}, "unit": "bytes"}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "storage_db_file_bytes", "legendFormat": "db file", "refId": "A"}]
    },
    {
      "title": "Submissions by status",
      "type": "piechart",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 15},
      "id": 9,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "pieType": "donut", "tooltip": {"mode": "single"}, "legend": {"displayMode": "table", "placement": "right", "values": ["value"], "showLegend": true}, "displayLabels": ["percent"]},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "submissions_by_status_total", "legendFormat": "{{status}}", "refId": "A"}]
    },
    {
      "title": "Content & Chat",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "id": 103,
      "panels": []
    },
    {
      "title": "Users",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 24},
      "id": 10,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "users_total", "refId": "A"}]
    },
    {
      "title": "Conferences",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 24},
      "id": 11,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "conferences_total", "refId": "A"}]
    },
    {
      "title": "Identities",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 24},
      "id": 12,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "conference_identities_total", "refId": "A"}]
    },
    {
      "title": "Chat messages",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 24},
      "id": 13,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "chat_messages_total", "refId": "A"}]
    },
    {
      "title": "Open chat reports",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 24},
      "id": 14,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 5}, {"color": "red", "value": 20}]}}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "chat_reports_open_total", "refId": "A"}]
    },
    {
      "title": "Expert bookings",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 24},
      "id": 15,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "textMode": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}, "overrides": []},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${datasource}"}, "expr": "expert_bookings_total", "refId": "A"}]
    }
