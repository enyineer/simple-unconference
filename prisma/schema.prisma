// Prisma schema — see https://pris.ly/d/prisma-schema
// Source of truth for the DB. Auto-migrations via `bunx prisma migrate dev`.

generator client {
  provider = "prisma-client-js"
}

// URL is configured in /prisma.config.ts (Prisma 7+).
datasource db {
  provider = "sqlite"
}

// Global account. Reserved for conference *owners*. Participants and moderators
// use ConferenceIdentity, which is scoped per-conference and never leaks across
// conferences.
model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  name          String?
  passwordHash  String   @map("password_hash")
  createdAt     DateTime @default(now()) @map("created_at")

  sessions             Session[]
  ownedConferences     Conference[]         @relation("ConferenceOwner")
  conferenceIdentities ConferenceIdentity[]
  chatBansIssued       ConferenceIdentity[] @relation("ChatBans")
  chatReportsResolved  MessageReport[]

  @@map("users")
}

// A session belongs to exactly one principal — either a global User (owner)
// or a ConferenceIdentity (participant/moderator). Enforced in code, not by
// the DB (sqlite has no native CHECK across nullable FKs at the cost we want).
model Session {
  token                String   @id
  userId               Int?     @map("user_id")
  conferenceIdentityId Int?     @map("conference_identity_id")
  createdAt            DateTime @default(now()) @map("created_at")
  expiresAt            DateTime @map("expires_at")

  user     User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  identity ConferenceIdentity? @relation(fields: [conferenceIdentityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conferenceIdentityId])
  @@map("sessions")
}

model Conference {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String   @unique
  ownerId       Int      @map("owner_id")
  owner         User     @relation("ConferenceOwner", fields: [ownerId], references: [id])
  designSystem  String   @default("github") @map("design_system")
  // IANA timezone (e.g. "Europe/Berlin"). All slot wall-clock times are
  // interpreted in this zone — separate from where the organizer happens to
  // sit when scheduling.
  timezone      String   @default("UTC")
  // Default avoid-repeats mode for mixer slots in this conference. When true
  // (the default), new mixer slots inherit "exclusive mix" — the algorithm
  // tries not to put two participants in the same room across mixers. Owners
  // can flip this from the Settings tab; per-slot overrides live on AgendaSlot.
  mixerAvoidRepeatsDefault Boolean @default(true) @map("mixer_avoid_repeats_default")
  // Default cap on how many times a published submission can be placed
  // (counts both static TrackAssignments and unconference placements).
  // `null` = unlimited reuse; `1` (the default) = each session is used once
  // and then drops out of the assignment pool and the participant Sessions
  // overview. Mods/owners override per submission via Submission.maxPlacements.
  submissionMaxPlacementsDefault Int? @default(1) @map("submission_max_placements_default")
  // When false, only owners + moderators can create new submissions in this
  // conference. Participants get a 403 from submissions.create and the UI
  // hides the "Submit a session" button for them. Default true so the
  // out-of-the-box behaviour matches an open unconference.
  participantSubmissionsEnabled Boolean @default(true) @map("participant_submissions_enabled")
  createdAt     DateTime @default(now()) @map("created_at")

  identities    ConferenceIdentity[]
  invites       ConferenceInvite[]
  joinLink      ConferenceJoinLink?
  rooms         Room[]
  submissions   Submission[]
  agendaSlots   AgendaSlot[]
  slotSeries    SlotSeries[]
  expertPools   ExpertRoomPool[]
  experts       Expert[]
  conversations Conversation[]

  @@map("conferences")
}

// Roles within a conference. "owner" is implied by Conference.ownerId and is
// never stored here — an owner who participates in their own conference gets
// an identity row with role=moderator and ownerUserId set.
enum IdentityRole {
  participant
  moderator
}

enum ProfileEntryCategory {
  link
  contact
}

// Per-conference identity. `email` is unique within a conference only — the
// same address may exist in multiple conferences as completely independent
// accounts (different passwords, names, calendar feeds, color-mode prefs).
model ConferenceIdentity {
  id            Int          @id @default(autoincrement())
  conferenceId  Int          @map("conference_id")
  email         String
  // Null until the participant claims their invite (or completes signup via
  // join link). A null passwordHash means the identity exists but cannot log in.
  passwordHash  String?      @map("password_hash")
  name          String?
  role          IdentityRole @default(participant)
  // Per-identity light/dark preference (was on User pre-migration).
  colorMode     String       @default("auto") @map("color_mode")
  // Opaque token for this identity's iCal feed. Per-conference, so no
  // cross-conference schedule leak.
  calendarToken String?      @unique @map("calendar_token")
  // Set when this identity was auto-minted for the conference owner so they
  // can submit/star/get-assigned in their own conference.
  ownerUserId   Int?         @map("owner_user_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  claimedAt     DateTime?    @map("claimed_at")
  profilePublished           Boolean   @default(false) @map("profile_published")
  bio                        String?
  pronouns                   String?
  title                      String?
  company                    String?
  avatarPath                 String?   @map("avatar_path")
  // Content hash (first 16 hex chars of sha256 of the resized webp) so we can
  // build immutable, CDN-cacheable URLs like /api/avatars/<slug>/<id>/<hash>.
  // Cleared along with avatarPath on deleteAvatar.
  avatarHash                 String?   @map("avatar_hash")
  profileCompletionDismissed Boolean   @default(false) @map("profile_completion_dismissed")
  // Per-identity chat preferences and ban state. See plans/chat.md Phase 1.
  chatEnabled                Boolean   @default(true)  @map("chat_enabled")
  chatReadReceiptsEnabled    Boolean   @default(true)  @map("chat_read_receipts_enabled")
  chatBannedAt               DateTime? @map("chat_banned_at")
  chatBannedReason           String?   @map("chat_banned_reason")
  chatBannedByUserId         Int?      @map("chat_banned_by_user_id")

  conference   Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  ownerUser    User?      @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  chatBannedBy User?      @relation("ChatBans", fields: [chatBannedByUserId], references: [id], onDelete: SetNull)

  sessions             Session[]
  submissions          Submission[]
  stars                Star[]
  userAssignments      UserAssignment[]
  claimedInvites       ConferenceInvite[] @relation("ClaimedInvite")
  expertProfile        Expert?
  expertBookings       ExpertBooking[]    @relation("ExpertBookingBooker")
  notifications        Notification[]
  profileEntries       ProfileEntry[]
  profileTags          ProfileTag[]
  conversationsAsLow   Conversation[]     @relation("ConversationLow")
  conversationsAsHigh  Conversation[]     @relation("ConversationHigh")
  sentMessages         Message[]
  filedReports         MessageReport[]    @relation("MessageReportsFiled")
  chatBlocksMade       ChatBlock[]        @relation("ChatBlockBlocker")
  chatBlocksReceived   ChatBlock[]        @relation("ChatBlockBlocked")

  @@unique([conferenceId, email])
  @@index([conferenceId])
  @@index([ownerUserId])
  @@map("conference_identities")
}

// Moderator-issued one-time invite. The participant clicks the link and sets
// their own password to mint a ConferenceIdentity. Tokens are opaque hex.
model ConferenceInvite {
  id                  Int          @id @default(autoincrement())
  conferenceId        Int          @map("conference_id")
  email               String
  token               String       @unique
  role                IdentityRole @default(participant)
  createdAt           DateTime     @default(now()) @map("created_at")
  expiresAt           DateTime     @map("expires_at")
  claimedAt           DateTime?    @map("claimed_at")
  claimedByIdentityId Int?         @map("claimed_by_identity_id")

  conference        Conference          @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  claimedByIdentity ConferenceIdentity? @relation("ClaimedInvite", fields: [claimedByIdentityId], references: [id], onDelete: SetNull)

  @@index([conferenceId])
  @@index([conferenceId, email])
  @@map("conference_invites")
}

// Owner-managed secret URL for open self-signup per conference. One row per
// conference (the conferenceId is the primary key). Rotating issues a new
// token, invalidating any previously shared link.
model ConferenceJoinLink {
  conferenceId Int       @id @map("conference_id")
  token        String    @unique
  enabled      Boolean   @default(false)
  expiresAt    DateTime? @map("expires_at")
  maxUses      Int?      @map("max_uses")
  usedCount    Int       @default(0) @map("used_count")
  createdAt    DateTime  @default(now()) @map("created_at")
  rotatedAt    DateTime? @map("rotated_at")

  conference Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)

  @@map("conference_join_links")
}

model Room {
  id           Int    @id @default(autoincrement())
  conferenceId Int    @map("conference_id")
  name         String
  capacity     Int
  // Free-text description (where to find the room, accessibility notes, etc.)
  description  String?

  conference            Conference              @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  trackAssignments      TrackAssignment[]
  unconferencePlacements UnconferencePlacement[]
  slotMemberships       SlotRoom[]
  seriesMemberships     SeriesRoom[]
  tags                  RoomTag[]
  userAssignments       UserAssignment[]
  expertPoolMemberships ExpertRoomPoolRoom[]
  expertRoomMemberships ExpertRoom[]
  expertBookings        ExpertBooking[]
  preAssignedSubmissions Submission[]          @relation("SubmissionPreAssignedRoom")

  @@index([conferenceId])
  @@map("rooms")
}

// Per-room labels (e.g. "projector", "ground floor", "wheelchair-accessible").
model RoomTag {
  id     Int    @id @default(autoincrement())
  roomId Int    @map("room_id")
  value  String

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, value])
  @@index([roomId])
  @@map("room_tags")
}

enum SubmissionStatus {
  submitted
  published
  rejected
}

model Submission {
  id           Int              @id @default(autoincrement())
  conferenceId Int              @map("conference_id")
  // FK to ConferenceIdentity.id (was User.id pre-migration). Column name kept
  // as submitter_id to reduce churn in query code; the *relation* now resolves
  // to a per-conference identity.
  submitterId  Int              @map("submitter_id")
  title        String
  description  String           @default("")
  status       SubmissionStatus @default(submitted)
  // Per-submission override of the conference's max-placements cap. `null`
  // means inherit Conference.submissionMaxPlacementsDefault. A submission
  // counts as "finished" when its placement count reaches the effective cap;
  // finished submissions are excluded from unconference pool selection and
  // hidden from the participant Sessions overview.
  maxPlacements    Int?    @map("max_placements")
  // Manual moderator override — when true, the submission is finished
  // regardless of placement count (e.g. speaker withdrew; talk already
  // delivered externally). Mods/owners flip this from the Sessions tab.
  manuallyFinished Boolean @default(false) @map("manually_finished")
  // Moderator-only pre-assignment to a specific room. When set, the
  // unconference assignment algorithm places this submission in this room
  // for every slot it lands in, overriding the star-based placement. The
  // server refuses to run an assignment for a slot where two eligible
  // pre-assigned submissions would compete for the same room, or where a
  // pre-assigned room isn't in the slot's effective room set.
  preAssignedRoomId Int? @map("pre_assigned_room_id")
  // Moderator-only opt-in: when true, this session can be placed (or be
  // hosted by its submitter) in multiple agenda slots whose times overlap.
  // Default (false) is "exclusive" — the assignment algorithm refuses to
  // schedule the same session in overlapping slots and also refuses to
  // schedule a different session whose submitter is already speaking in
  // an overlapping slot. Mods flip this on for sessions designed to run
  // multiple times in parallel (e.g. a recurring workshop).
  allowOverlappingPlacements Boolean @default(false) @map("allow_overlapping_placements")
  createdAt    DateTime         @default(now()) @map("created_at")

  conference          Conference              @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  submitter           ConferenceIdentity      @relation(fields: [submitterId], references: [id])
  preAssignedRoom     Room?                   @relation("SubmissionPreAssignedRoom", fields: [preAssignedRoomId], references: [id], onDelete: SetNull)
  stars               Star[]
  trackAssignments    TrackAssignment[]
  placements          UnconferencePlacement[]
  userAssignments     UserAssignment[]
  tags                SubmissionTag[]
  requirements        SubmissionRequirement[]
  roomRequirements    SubmissionRoomRequirement[]
  slotMemberships     SlotSubmission[]
  seriesMemberships   SeriesSubmission[]

  @@index([conferenceId])
  @@index([conferenceId, status])
  @@map("submissions")
}

// Free-form labels the submitter (or a moderator) attaches to a talk.
// Examples: "workshop", "discussion", "lightning". Unique per submission.
model SubmissionTag {
  id           Int    @id @default(autoincrement())
  submissionId Int    @map("submission_id")
  value        String

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, value])
  @@index([submissionId])
  @@map("submission_tags")
}

// Things attendees need to bring/have. Examples: "laptop", "github account".
model SubmissionRequirement {
  id           Int    @id @default(autoincrement())
  submissionId Int    @map("submission_id")
  value        String

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, value])
  @@index([submissionId])
  @@map("submission_requirements")
}

// Room-side requirements the session needs from its assigned room. Tag
// values must match an existing `RoomTag.value` in the conference (the
// picker only offers tags that exist on at least one room). The assignment
// algorithm filters candidate rooms to those whose tag set is a superset
// of these values. The set is "approved" implicitly by the session being
// `published` — submitters can't edit a published session, so once a mod
// publishes, the tags are frozen.
model SubmissionRoomRequirement {
  id           Int    @id @default(autoincrement())
  submissionId Int    @map("submission_id")
  value        String

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, value])
  @@index([submissionId])
  @@map("submission_room_requirements")
}

model Star {
  // FK to ConferenceIdentity.id (was User.id pre-migration). Column kept as
  // user_id; relation accessor is `identity`.
  userId       Int      @map("user_id")
  submissionId Int      @map("submission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  identity   ConferenceIdentity @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@id([userId, submissionId])
  @@index([submissionId])
  @@map("stars")
}

enum SlotType {
  normal
  unconference
  // Mixer: pick rooms, every participant auto-assigned to a room (capacity-aware
  // even split). Reuses `unconfUseAllRooms` / `selectedRooms` for room selection
  // — same mechanic, different output (no submission, just room).
  mixer
}

model AgendaSlot {
  id           Int      @id @default(autoincrement())
  conferenceId Int      @map("conference_id")
  type         SlotType
  title        String?
  description  String?
  startsAt     DateTime @map("starts_at")
  endsAt       DateTime @map("ends_at")

  // Per-slot assignment configuration. `unconfUseAllRooms` is shared between
  // unconference + mixer slots (both need a room scope). `unconfUseAllSubmissions`
  // is unconference-only. When useAll* is true, assignment uses every room /
  // every published submission in the conference; when false, only the
  // explicitly selected ones in the join tables below.
  //
  // **Series-owned config:** when `seriesId` is non-null, the type, the
  // unconf*/mixer* config fields, and the `SlotRoom` / `SlotSubmission`
  // join rows on THIS slot are ignored — `SlotSeries` is the source of
  // truth. Reads must go through `effectiveSlotConfig()` in
  // [src/server/lib/slot-config.ts]. On detach, the resolved series config
  // is snapshotted back onto these fields so the slot becomes a standalone
  // slot with no behaviour change.
  unconfUseAllRooms       Boolean @default(true) @map("unconf_use_all_rooms")
  unconfUseAllSubmissions Boolean @default(true) @map("unconf_use_all_submissions")
  // When true (default), an unconference assignment won't put a user in the
  // same submission they've already attended in an earlier unconference slot
  // in this conference. Submitters are always assigned to their own session
  // when it's placed, regardless of this flag.
  unconfAvoidRepeats      Boolean @default(true) @map("unconf_avoid_repeats")
  // Mixer-only override of Conference.mixerAvoidRepeatsDefault. Null means
  // "inherit the conference default"; true forces "exclusive mix" (avoid
  // re-pairing against other exclusive mixers); false forces a fresh shuffle
  // that ignores prior mixers entirely.
  mixerAvoidRepeats       Boolean? @map("mixer_avoid_repeats")

  // Optional FK linking this slot to a SlotSeries. When set, the slot is a
  // "linked offering" of the series — `type` and the unconf*/mixer* config
  // come from the series, not from this row. Null = standalone slot (the
  // historical, default shape).
  //
  // **Placement-cap semantics:** when a Submission is placed in multiple
  // sibling offerings (whether via TrackAssignment or the unconference
  // algorithm), each placement counts independently against the submission's
  // effective max-placements cap. A session that runs in three siblings of
  // the same series burns three placement slots. This is intentional —
  // placements measure actual room-time used, not unique content. Mod UI
  // must surface this clearly.
  seriesId Int? @map("series_id")

  conference              Conference              @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  series                  SlotSeries?             @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  trackAssignments        TrackAssignment[]
  unconferencePlacements  UnconferencePlacement[]
  userAssignments         UserAssignment[]
  selectedRooms           SlotRoom[]
  selectedSubmissions     SlotSubmission[]

  @@index([conferenceId, startsAt])
  @@index([seriesId])
  @@map("agenda_slots")
}

// A SlotSeries groups linked offerings — multiple AgendaSlot rows that share
// configuration (type, room pool, submission pool, assignment flags) and
// differ only in time. Created when a mod duplicates a slot. Edits to the
// series propagate to every member; per-instance title/description and time
// stay on the individual AgendaSlot.
//
// The cross-sibling avoid-repeats behaviour (don't place the same user in
// the same submission across two siblings of the same series) is gated by
// `avoidRepeatsAcrossSiblings`. This is *in addition to* the per-slot
// `unconfAvoidRepeats` semantics, which the algorithm already enforces
// against earlier-run slots in the same conference.
model SlotSeries {
  id           Int      @id @default(autoincrement())
  conferenceId Int      @map("conference_id")
  type         SlotType
  title        String?
  description  String?

  unconfUseAllRooms       Boolean @default(true) @map("unconf_use_all_rooms")
  unconfUseAllSubmissions Boolean @default(true) @map("unconf_use_all_submissions")
  unconfAvoidRepeats      Boolean @default(true) @map("unconf_avoid_repeats")
  mixerAvoidRepeats       Boolean? @map("mixer_avoid_repeats")

  // When true (default), the assignment algorithm treats sibling offerings of
  // this series as a single user-eligibility scope: a participant placed in
  // submission X via sibling A is not eligible to be re-placed in submission X
  // via sibling B. Mods opt out (false) for series where re-attendance is
  // intentionally allowed (e.g. open discussion blocks that run multiple times).
  avoidRepeatsAcrossSiblings Boolean @default(true) @map("avoid_repeats_across_siblings")

  createdAt DateTime @default(now()) @map("created_at")

  conference          Conference         @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  slots               AgendaSlot[]
  selectedRooms       SeriesRoom[]
  selectedSubmissions SeriesSubmission[]

  @@index([conferenceId])
  @@map("slot_series")
}

// Series-level analogue of SlotRoom. Restricts which rooms participate in
// every offering's assignment when `unconfUseAllRooms = false`.
model SeriesRoom {
  seriesId Int @map("series_id")
  roomId   Int @map("room_id")

  series SlotSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  room   Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([seriesId, roomId])
  @@map("series_rooms")
}

// Series-level analogue of SlotSubmission.
model SeriesSubmission {
  seriesId     Int @map("series_id")
  submissionId Int @map("submission_id")

  series     SlotSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@id([seriesId, submissionId])
  @@map("series_submissions")
}

// Restricts which rooms participate in an unconference slot's assignment.
// Empty (when useAllRooms = false) means "no rooms" — assignment will produce
// no placements. Ignored when useAllRooms = true.
model SlotRoom {
  slotId Int @map("slot_id")
  roomId Int @map("room_id")

  slot AgendaSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  room Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([slotId, roomId])
  @@map("slot_rooms")
}

// Restricts which submissions are eligible for an unconference slot.
model SlotSubmission {
  slotId       Int @map("slot_id")
  submissionId Int @map("submission_id")

  slot       AgendaSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@id([slotId, submissionId])
  @@map("slot_submissions")
}

// Static slot (type=normal): admin picks which talk runs in which room.
// `submissionId` links a published submission; `title` is an ad-hoc label when
// there's no submission (e.g. a keynote by an invited guest). `speakers` is a
// free-text comma-separated list of speaker names (so external speakers without
// accounts can be credited).
model TrackAssignment {
  id           Int     @id @default(autoincrement())
  slotId       Int     @map("slot_id")
  roomId       Int     @map("room_id")
  // Every planned-slot track is anchored to a Submission. The Submission
  // supplies the title and the submitter (who is credited as the speaker
  // on the schedule). Mods who want an external/invited speaker first
  // create a Submission for them.
  submissionId Int     @map("submission_id")
  // Optional addendum text appended to the submitter's name when listing
  // speakers. Use it for co-presenters or guest names that aren't first-class
  // participants. Null/empty = just show the submission's submitter.
  speakers     String?
  // When true, this static track is force-attended: it shows up in every
  // participant's myAssignments + iCal feed regardless of whether they've
  // starred the underlying submission, and the schedule cannot be opted out
  // of. Used for keynotes, opening/closing ceremonies, etc. Only valid on
  // normal-type slots (server enforces this in setTrack).
  mandatory    Boolean @default(false)

  slot         AgendaSlot           @relation(fields: [slotId], references: [id], onDelete: Cascade)
  room         Room                 @relation(fields: [roomId], references: [id], onDelete: Cascade)
  submission   Submission           @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  requirements TrackRequirement[]

  @@unique([slotId, roomId])
  @@index([submissionId])
  @@map("track_assignments")
}

// Per-track requirements (e.g. "laptop", "github account"). Separate from
// SubmissionRequirement so a mod can attach prerequisites at the schedule
// level (e.g. specific to this particular offering of the session).
model TrackRequirement {
  id      Int    @id @default(autoincrement())
  trackId Int    @map("track_id")
  value   String

  track TrackAssignment @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([trackId, value])
  @@index([trackId])
  @@map("track_requirements")
}

// Output of the unconference assignment algorithm: which submission lives in which room.
model UnconferencePlacement {
  slotId       Int @map("slot_id")
  submissionId Int @map("submission_id")
  roomId       Int @map("room_id")

  slot       AgendaSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  room       Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([slotId, submissionId])
  @@unique([slotId, roomId])
  @@map("unconference_placements")
}

// Per-slot output of an assignment algorithm: which identity ends up where.
// - For unconference slots: `submissionId` set, `roomId` derived (denormalized
//   alongside for cheap reads).
// - For mixer slots: `roomId` set, `submissionId` null (no talk; just a room).
// - Future slot types can use either combination.
model UserAssignment {
  slotId       Int     @map("slot_id")
  // FK to ConferenceIdentity.id (was User.id pre-migration). Column kept as
  // user_id; relation accessor is `identity`.
  userId       Int     @map("user_id")
  submissionId Int?    @map("submission_id")
  roomId       Int?    @map("room_id")
  // True when the identity picked this session themselves (vs being placed by
  // the algorithm). Manual picks are preserved across re-runs — the algorithm
  // treats them as fixed inputs rather than reshuffling.
  manual       Boolean @default(false)

  slot       AgendaSlot         @relation(fields: [slotId], references: [id], onDelete: Cascade)
  identity   ConferenceIdentity @relation(fields: [userId], references: [id], onDelete: Cascade)
  submission Submission?        @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  room       Room?              @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@id([slotId, userId])
  @@index([userId])
  @@index([userId, submissionId])
  @@map("user_assignments")
}

// ===========================================================================
// EXPERT BOOKINGS
//
// Participants can book a 1:1 chat with an "expert" — any ConferenceIdentity
// in the conference that an owner/moderator has promoted. Experts define one
// or more bookable timeframes (start/end + slot duration); the system derives
// the individual bookable slots from those. A booking is an ExpertBooking row
// that pins a single slot + room at creation time.
// ===========================================================================

// Conference-scoped, named pool of rooms reserved for expert conversations.
// Owners/mods can create multiple pools and either assign an expert to a pool
// (any room from the pool can host a booking) or to a specific set of rooms
// via ExpertRoom.
model ExpertRoomPool {
  id           Int      @id @default(autoincrement())
  conferenceId Int      @map("conference_id")
  name         String
  createdAt    DateTime @default(now()) @map("created_at")

  conference Conference           @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  rooms      ExpertRoomPoolRoom[]
  experts    Expert[]

  @@unique([conferenceId, name])
  @@index([conferenceId])
  @@map("expert_room_pools")
}

model ExpertRoomPoolRoom {
  poolId Int @map("pool_id")
  roomId Int @map("room_id")

  pool ExpertRoomPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  room Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([poolId, roomId])
  @@map("expert_room_pool_rooms")
}

// Per-conference expert promotion. One Expert per identity. When `poolId` is
// set, bookings draw rooms from the pool; when null, bookings draw from the
// `ExpertRoom` rows; when both are empty, the expert cannot be booked.
model Expert {
  id           Int      @id @default(autoincrement())
  conferenceId Int      @map("conference_id")
  identityId   Int      @unique @map("identity_id")
  poolId       Int?     @map("pool_id")
  // Free-text expertise blurb shown to participants on the Experts tab.
  bio          String?
  createdAt    DateTime @default(now()) @map("created_at")

  conference Conference         @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  identity   ConferenceIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  pool       ExpertRoomPool?    @relation(fields: [poolId], references: [id], onDelete: SetNull)
  rooms      ExpertRoom[]
  timeframes ExpertTimeframe[]
  bookings   ExpertBooking[]

  @@index([conferenceId])
  @@map("experts")
}

// Per-expert room overrides. Only consulted when Expert.poolId is null.
model ExpertRoom {
  expertId Int @map("expert_id")
  roomId   Int @map("room_id")

  expert Expert @relation(fields: [expertId], references: [id], onDelete: Cascade)
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([expertId, roomId])
  @@map("expert_rooms")
}

// A bookable window. Slots are derived deterministically:
//   for (t = startsAt; t + slotDurationMinutes*60s <= endsAt; t += slotDurationMinutes*60s)
//     yield { startsAt: t, endsAt: t + slotDurationMinutes*60s };
// A booking pins one such derived slot to a single ExpertBooking row.
model ExpertTimeframe {
  id                  Int      @id @default(autoincrement())
  expertId            Int      @map("expert_id")
  startsAt            DateTime @map("starts_at")
  endsAt              DateTime @map("ends_at")
  slotDurationMinutes Int      @map("slot_duration_minutes")
  createdAt           DateTime @default(now()) @map("created_at")

  expert   Expert          @relation(fields: [expertId], references: [id], onDelete: Cascade)
  bookings ExpertBooking[]

  @@index([expertId])
  @@map("expert_timeframes")
}

// A confirmed booking. The room is locked in at booking time (first available
// in the expert's pool/list) and stays even if the expert's room config later
// changes — cancelling/recreating is the way to reshuffle.
model ExpertBooking {
  id          Int      @id @default(autoincrement())
  expertId    Int      @map("expert_id")
  timeframeId Int      @map("timeframe_id")
  // Booker is a ConferenceIdentity in the same conference. Names/emails are
  // masked from non-mods (privacy parity with Submissions.submitter_email).
  bookerId    Int      @map("booker_id")
  roomId      Int      @map("room_id")
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime @map("ends_at")
  createdAt   DateTime @default(now()) @map("created_at")

  expert    Expert             @relation(fields: [expertId], references: [id], onDelete: Cascade)
  timeframe ExpertTimeframe    @relation(fields: [timeframeId], references: [id], onDelete: Cascade)
  booker    ConferenceIdentity @relation("ExpertBookingBooker", fields: [bookerId], references: [id], onDelete: Cascade)
  room      Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)

  // One booking per (expert, exact slot start). Enforces "no double-booking
  // the same expert at the same time" at the DB level.
  @@unique([expertId, startsAt])
  // Enforces "the same room cannot host two overlapping bookings" only via
  // index lookup (full overlap check is in code); index speeds it up.
  @@index([roomId, startsAt])
  @@index([expertId])
  @@index([bookerId])
  @@map("expert_bookings")
}

// ===========================================================================
// NOTIFICATIONS
//
// Simple in-app notifications targeted at a ConferenceIdentity (so they are
// per-conference: an owner who participates in multiple conferences gets a
// separate inbox per conference). Each row carries an optional CTA — the
// frontend renders `ctaLabel` as a button that navigates to `ctaHref`.
// Hrefs use the custom `tab:<key>` form to switch tabs within the current
// conference page (no full navigation needed for in-app jumps).
// ===========================================================================
model Notification {
  id         Int       @id @default(autoincrement())
  identityId Int       @map("identity_id")
  // Discriminator for icon/styling on the client.
  // Known kinds: "submission_published", "submission_rejected",
  // "submission_received" (mod-side), "unconf_assigned", "mixer_assigned",
  // "expert_booked", "expert_booking_cancelled", "chat_message", "chat_report",
  // "chat_warning".
  kind       String
  title      String
  body       String?
  ctaLabel   String?   @map("cta_label")
  ctaHref    String?   @map("cta_href")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  // Coalescing key for kinds that should collapse multiple events into a
  // single bell row (e.g. many chat messages from the same conversation
  // share dedupeKey="conv:<id>"). NULL means "don't coalesce" — SQLite
  // treats multiple NULLs in a unique column as distinct.
  dedupeKey   String? @map("dedupe_key")
  unreadCount Int     @default(1) @map("unread_count")

  identity ConferenceIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@unique([identityId, dedupeKey], map: "notifications_identity_dedupe_uniq")
  @@index([identityId, readAt])
  @@index([identityId, createdAt])
  @@map("notifications")
}

// ===========================================================================
// USER PROFILES
//
// Per-conference profile data attached to a ConferenceIdentity. Visibility is
// gated by `ConferenceIdentity.profilePublished` (the whole profile) plus
// per-entry `isPublic` for individual link/contact rows. Mods always see
// everything; participants see only published profiles and only the entries
// flagged public.
// ===========================================================================
model ProfileEntry {
  id         Int                  @id @default(autoincrement())
  identityId Int                  @map("identity_id")
  kind       String
  value      String
  href       String?
  category   ProfileEntryCategory
  isPublic   Boolean              @default(false) @map("is_public")
  position   Int                  @default(0)
  createdAt  DateTime             @default(now()) @map("created_at")

  identity ConferenceIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([identityId])
  @@map("profile_entries")
}

model ProfileTag {
  identityId Int      @map("identity_id")
  tag        String
  createdAt  DateTime @default(now()) @map("created_at")

  identity ConferenceIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@id([identityId, tag])
  @@index([identityId])
  @@map("profile_tags")
}

// ===========================================================================
// CHAT
//
// 1-on-1 messaging within a conference. A Conversation is uniquely identified
// by (conferenceId, identityIdLow, identityIdHigh) — the pair is always sorted
// low<high so the unique index works regardless of who initiates.
//
// Privacy + lifecycle rules (see plans/chat.md Phase 0):
//   - canChatWith requires both sides to be profilePublished + chatEnabled,
//     neither banned, no ChatBlock either direction. Mods+ bypass the
//     published check but still respect ban/block.
//   - Messages are soft-deleted (deletedAt + deletedReason) so reports remain
//     reviewable. Hard-delete only at conference purge time, and only when no
//     unresolved reports reference the message (MessageReport.onDelete:Restrict
//     blocks conference deletion until reports are resolved).
//   - Read receipts: receiver's chatReadReceiptsEnabled toggles whether
//     Message.readAt is returned to the sender. Receiver always sees their
//     own read state locally for unread badging.
// ===========================================================================
model Conversation {
  id             Int       @id @default(autoincrement())
  conferenceId   Int       @map("conference_id")
  // Sorted pair: always identityIdLow < identityIdHigh. Enforced by the
  // findOrCreateConversation helper, not the DB.
  identityIdLow  Int       @map("identity_id_low")
  identityIdHigh Int       @map("identity_id_high")
  // Message-request state: starts false on first message from a stranger.
  // Flipped true when the receiver replies OR explicitly accepts. Until then
  // the conversation only shows up in the receiver's "Requests" bucket and
  // the sender can't send further messages on it.
  accepted       Boolean   @default(false)
  acceptedAt     DateTime? @map("accepted_at")
  lastMessageAt  DateTime? @map("last_message_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conference Conference         @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  low        ConferenceIdentity @relation("ConversationLow", fields: [identityIdLow], references: [id], onDelete: Cascade)
  high       ConferenceIdentity @relation("ConversationHigh", fields: [identityIdHigh], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([conferenceId, identityIdLow, identityIdHigh])
  @@index([conferenceId, lastMessageAt])
  @@index([identityIdLow, lastMessageAt])
  @@index([identityIdHigh, lastMessageAt])
  @@map("conversations")
}

model Message {
  id               Int       @id @default(autoincrement())
  conversationId   Int       @map("conversation_id")
  senderIdentityId Int       @map("sender_identity_id")
  body             String
  createdAt        DateTime  @default(now()) @map("created_at")
  editedAt         DateTime? @map("edited_at")
  // Soft-delete: when set, body is hidden from clients but row stays so
  // reports remain reviewable. deletedReason is "user" | "moderator"
  // | "account_deleted" | "conference_deleted".
  deletedAt        DateTime? @map("deleted_at")
  deletedReason    String?   @map("deleted_reason")
  // When the OTHER participant read this message. Stripped from sender's
  // MessageOut if the receiver has chatReadReceiptsEnabled=false.
  readAt           DateTime? @map("read_at")

  conversation Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       ConferenceIdentity @relation(fields: [senderIdentityId], references: [id], onDelete: Cascade)
  revisions    MessageRevision[]
  reports      MessageReport[]

  @@index([conversationId, id])
  @@index([conversationId, createdAt])
  @@map("messages")
}

// Snapshot of a Message body BEFORE an edit. Written eagerly by chat.edit so
// moderators reviewing a reported message see the full revision chain.
model MessageRevision {
  id        Int      @id @default(autoincrement())
  messageId Int      @map("message_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
  @@map("message_revisions")
}

model MessageReport {
  id                 Int       @id @default(autoincrement())
  messageId          Int       @map("message_id")
  reporterIdentityId Int       @map("reporter_identity_id")
  reason             String
  createdAt          DateTime  @default(now()) @map("created_at")
  resolvedAt         DateTime? @map("resolved_at")
  resolvedByUserId   Int?      @map("resolved_by_user_id")
  // Action taken by the resolving moderator: "dismiss" | "warn" | "ban".
  action             String?

  // Restrict so that hard-deleting a Message is impossible while reports
  // reference it. Soft-delete is always available via deletedAt + reason.
  message    Message            @relation(fields: [messageId], references: [id], onDelete: Restrict)
  reporter   ConferenceIdentity @relation("MessageReportsFiled", fields: [reporterIdentityId], references: [id], onDelete: Cascade)
  resolvedBy User?              @relation(fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([resolvedAt, createdAt])
  @@map("message_reports")
}

// Per-user block. Hides the conversation in both directions and prevents new
// conversations between the pair. Separate from the global chatEnabled toggle.
model ChatBlock {
  blockerIdentityId Int      @map("blocker_identity_id")
  blockedIdentityId Int      @map("blocked_identity_id")
  createdAt         DateTime @default(now()) @map("created_at")

  blocker ConferenceIdentity @relation("ChatBlockBlocker", fields: [blockerIdentityId], references: [id], onDelete: Cascade)
  blocked ConferenceIdentity @relation("ChatBlockBlocked", fields: [blockedIdentityId], references: [id], onDelete: Cascade)

  @@id([blockerIdentityId, blockedIdentityId])
  @@index([blockedIdentityId])
  @@map("chat_blocks")
}
